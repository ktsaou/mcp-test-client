{
  "name": "mcp-test-client",
  "version": "1.3.1",
  "description": "Zero-install, browser-only test client for public Model Context Protocol (MCP) servers.",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": true,
  "homepage": "https://ktsaou.github.io/mcp-test-client/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktsaou/mcp-test-client.git"
  },
  "bugs": {
    "url": "https://github.com/ktsaou/mcp-test-client/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && cp -r docs specs dist/",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps",
    "check:bundle": "node scripts/bundle-budget.mjs",
    "clean": "rm -rf dist coverage playwright-report test-results"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@mantine/core": "^9.1.0",
    "@mantine/hooks": "^9.1.0",
    "@mantine/modals": "^9.1.0",
    "@mantine/notifications": "^9.1.0",
    "@mantine/spotlight": "^9.1.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "cmdk": "^1.1.1",
    "gpt-tokenizer": "^3.4.0",
    "nanoid": "5.1.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-resizable-panels": "^4.10.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
